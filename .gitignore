# Secrets — never commit
.env
*.key

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
*.egg-info/

# Test outputs (large, regenerable)
test_a_output.json
test_b_output.json

# Data caches (regenerable; data lives local, not in repo)
data/
.cache/
cache/
# ...EXCEPT the price-history file cache, which is intentionally shipped so the
# chart (and the no-API-key fixture demo) work offline. api.py reads it; it's
# small + regenerable via yfinance. The LLM caches (decoder/evidence/synth) are
# NOT shipped — they moved into SQLite llm_cache at v0.6.
!cache/price_history/
!cache/price_history/*.json

# Legacy per-run JSON outputs (v0.5 and earlier; superseded by SQLite, regenerable)
outputs/

# SQLite databases (v0.6+) — local, regenerable via `python migrate_to_sqlite.py`
*.db
*.db-journal
*.db-wal
*.db-shm

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
