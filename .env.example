# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- LLM provider -----------------------------------------------------------
# Which backend to use. "miromind" (default) is an agentic Deep Research model
# (real web search → grounded evidence). "tokendance" is an OpenAI-compatible
# gateway (DeepSeek V4 Pro etc.) — a plain chat model, so it does NOT browse the
# web; the evidence + market-narrative layers honest-empty on it unless you set
# ALLOW_UNGROUNDED_RESEARCH=1 (which lets the model answer from memory, clearly
# unverified — use only for exercising the UI, not for real research).
LLM_PROVIDER=miromind

# MiroMind (used when LLM_PROVIDER=miromind)
MIROMIND_API_KEY=sk_live_xxx_replace_me

# TokenDance gateway (used when LLM_PROVIDER=tokendance)
#   base url + model defaults are baked in (https://tokendance.space/gateway/v1,
#   deepseek-v4-pro); override with LLM_BASE_URL / LLM_MODEL if needed.
# TOKENDANCE_API_KEY=sk-xxx_replace_me
# ALLOW_UNGROUNDED_RESEARCH=1     # opt-in: let the chat model answer research calls

# Wind AIFin Market (post-MVP; deferred per Q7)
# WIND_API_KEY=ak_xxx_replace_me
