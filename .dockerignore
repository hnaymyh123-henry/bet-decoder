*.db-journal
*.db-wal
*.db-shm
cache/
outputs/
data/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
*.egg-info/

# Tooling / VCS / agent worktrees
.git/
.gitignore
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db

