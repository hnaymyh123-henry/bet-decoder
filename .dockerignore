# Secrets — never bake into the image
.env
*.key

# Local caches (regenerable). NOTE: the pre-run demo DB (pricelens.db) is
# intentionally shipped so a deployed instance shows the four demo bets offline.
*.db-journal
*.db-wal
*.db-shm
*.bak
cache/
outputs/
data/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
*.egg-info/

# Tooling / VCS / agent worktrees
.git/
.gitignore
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Dev-only verification scripts and working drafts (not needed at runtime)
verify_m*.py
test_a_evidence.py
test_b_chat.py
PRD-draft.md
